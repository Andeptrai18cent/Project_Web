<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>
    <link rel="stylesheet" href="/css/styleForAdmin.css">
</head>
<body>
    <div class="container">
        <div class="navigation">
            <ul>
                <li>
                    <a href="#" data-section="dashboard" class="active">
                        <span class="icon"><i data-feather="code"></i></span>
                        <span class="title">Admin</span>
                    </a>
                </li>
                <li>
                    <a href="#" data-section="user">
                        <span class="icon"><i data-feather="user"></i></span>
                        <span class="title">User</span>
                    </a>
                </li>
                <li>
                    <a href="#" data-section="tasker">
                        <span class="icon"><i data-feather="users"></i></span>
                        <span class="title">Tasker</span>
                    </a>
                </li>
                <li>
                    <a href="#" data-section="settings">
                        <span class="icon"><i data-feather="settings"></i></span>
                        <span class="title">Settings</span>
                    </a>
                </li>
                <li>
                    <a href="#" data-section="sign-out">
                        <span class="icon"><i data-feather="log-out"></i></span>
                        <span class="title">Sign-Out</span>
                    </a>
                </li>
                <li>
                    <a href="#" data-section="password">
                        <span class="icon"><i data-feather="lock"></i></span>
                        <span class="title">Password</span>
                    </a>
                </li>
            </ul>
        </div>

        <div class="main">
            <div class="topbar">
                <div class="toggle">
                    <i data-feather="menu"></i>
                </div>
                <div class="search">
                    <label>
                        <input type="text" placeholder="Search here">
                        <i data-feather="search"></i>
                    </label>
                </div>
            </div>

            <!-- Dashboard Content -->
            <div class="content" id="dashboard-content">
                <div class="details">
                    <div class="recentOrders">
                        <div class="cardHeader">
                            <h2>Recent Order Tasks</h2>
                            <a href="#" class="btn">View All</a>
                        </div>
                        <table>
                            <thead>
                                <tr>
                                    <td>Oder-id</td>
                                    <td>Tasker-id</td>
                                    <td>Name</td>
                                    <td>Address</td>
                                    <td>Task</td>
                                    <td>Date</td>
                                    <td>Price</td>
                                    <td>Status</td>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>#221</td>
                                    <td>3412</td>
                                    <td>Thanh Nam</td>
                                    <td>Phung Khoang</td>
                                    <td>Clean-room</td>
                                    <td>14/2/2025</td>
                                    <td>156,000</td>
                                    <td><span class="status pending">Pending</span></td>
                                </tr>
                                <tr>
                                    <td>#121</td>
                                    <td>2211</td>
                                    <td>Vo An</td>
                                    <td>Van Quan</td>
                                    <td>Washing</td>
                                    <td>14/2/2025</td>
                                    <td>200,000</td>
                                    <td><span class="status inprogress">In Progress</span></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- User Content -->
          <div class="content hidden" id="user-content">
                <div class="details">
                    <div class="recentOrders">
                        <div class="cardHeader">
                            <h2>User Information</h2>
                            <a href="#" class="btn">View All</a>
                        </div>
                        <table>
                            <thead>
                                <tr>
                                    <td>User-name</td>
                                    <td>Name</td>
                                    <td>Address</td>
                                    <td>Phone</td>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Andeptrai18cent</td>
                                    <td>Vo Hoang An</td>
                                    <td>Thanh hoa rau ma</td>
                                    <td>0987654321</td>
                                    <td class = "actions">
                                        <button class="btn-edit">Edit</button>
                                        <button class="btn-deactivate">Deactivate</button>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Andeptrai18cent</td>
                                    <td>Vo Hoang An</td>
                                    <td>Thanh hoa rau ma</td>
                                    <td>0987654321</td>
                                    <td class = "actions">
                                        <button class="btn-edit">Edit</button>
                                        <button class="btn-deactivate">Deactivate</button>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
              

            <!-- Tasker Content -->
             <div class="content hidden" id="tasker-content">
                <div class="details">
                    <div class="recentOrders">
                        <div class="cardHeader">
                            <h2>User Information</h2>
                            <a href="#" class="btn">View All</a>
                        </div>
                        <table>
                            <thead>
                                <tr>
                                    <td>User-name</td>
                                    <td>Name</td>
                                    <td>Address</td>
                                    <td>Phone</td>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Andeptrai18cent</td>
                                    <td>Vo Hoang An</td>
                                    <td>Thanh hoa rau ma</td>
                                    <td>0987654321</td>
                                    <td class = "actions">
                                        <button class="btn-edit">Edit</button>
                                        <button class="btn-deactivate">Deactivate</button>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Andeptrai18cent</td>
                                    <td>Vo Hoang An</td>
                                    <td>Thanh hoa rau ma</td>
                                    <td>0987654321</td>
                                    <td class = "actions">
                                        <button class="btn-edit">Edit</button>
                                        <button class="btn-deactivate">Deactivate</button>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                        <div class="user-actions">
                    </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src ="/css/script.js"></script>
    <script src="https://unpkg.com/feather-icons"></script>
</body>
</html>